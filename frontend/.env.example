# Copiar para .env.local (nunca commitar .env.local)
# Variáveis NEXT_PUBLIC_* vão para o browser.

# Site (metadata, links absolutos). Com IP público fixo, use aqui; o CLI do Next só mostra IP LAN em "Network:".
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Nest: fallback quando o pedido não corre no browser (SSR) ou com NEXT_PUBLIC_API_DYNAMIC_HOST=false.
# Em dev no browser, com modo dinâmico (omissão), a API usa o mesmo host que a página na porta abaixo.
NEXT_PUBLIC_API_URL=http://localhost:3005

# Publicação atrás de Nginx com path /api (sem expor 3005 no browser):
# NEXT_PUBLIC_API_SAME_ORIGIN=true

# Porta do Nest no modo dinâmico (se não for 3005)
# NEXT_PUBLIC_API_PORT=3005

# Forçar URL fixa em dev: NEXT_PUBLIC_API_DYNAMIC_HOST=false

# Chamadas server-side (Docker / hostname interno)
# INTERNAL_API_URL=http://backend:3005

# Next dev: hosts para allowedDevOrigins (HMR); separados por vírgula — LAN, IP público fixo, etc.
NEXT_DEV_ALLOWED_ORIGINS=localhost,127.0.0.1

# SSR no mesmo servidor: API via loopback (evita hairpin quando NEXT_PUBLIC_API_URL é IP público)
# INTERNAL_API_URL=http://127.0.0.1:3005

# CORS no Nest: no backend/.env use DEV_FRONTEND_ORIGINS com o mesmo host:porta da UI (ex.: http://192.168.x.x:3000)

# --- Supabase no browser (reset password / cliente JS) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Auth / BFF (opcional) ---
# NEXT_PUBLIC_AUTH_USE_HTTPONLY_REFRESH=false
# NEXT_PUBLIC_AUTH_LOGIN_VIA_BFF=false
# AUTH_HTTPONLY_REFRESH=true
# JWT_REFRESH_EXPIRES_DAYS=30

# --- SEO ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Ferramentas ---
# ANALYZE=false

# Cookies: em produção com site só em HTTP (WAN por IP), omitir ou usar false.
# Com HTTPS (recomendado), o app detecta; ou force: COOKIE_SECURE=true
# COOKIE_SECURE=
# NEXT_PUBLIC_COOKIE_SECURE=

# --- Log de acesso (proxy) ---
# ACCESS_LOG_SILENT=true
# ACCESS_LOG_GEO=false
# Barra + permissão de geolocalização do aparelho (GPS) para logs; desligar: false
# NEXT_PUBLIC_ACCESS_CLIENT_GEO=false
