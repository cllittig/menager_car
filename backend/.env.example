# Copiar para .env e preencher (nunca commitar .env)
# Ver também: backend/config.env.template

# --- Ambiente / API ---
NODE_ENV=development
PORT=3005
# Escuta em todas as interfaces (main.ts); opcional
# HOST=0.0.0.0
# API_PREFIX=api

# LAN / telemóvel: mesma origem que o Next (lista separada por vírgula). Alinhar com frontend / CORS.
# DEV_FRONTEND_ORIGINS=http://192.168.1.10:3000

# --- Supabase (API Nest) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Senha DB + pooler (scripts: db:apply, security:validate, security:rollout — ver scripts/*.js)
# SUPABASE_DB_PASSWORD=
# Host exato do Session pooler (Supabase > Connect); não adivinhar aws-0 vs aws-1
# SUPABASE_POOLER_HOST=aws-1-sa-east-1.pooler.supabase.com
# SUPABASE_POOLER_REGION=sa-east-1
# SUPABASE_POOLER_PORT=5432
# MIGRATE_DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- JWT ---
JWT_SECRET=sua-chave-jwt-super-segura-minimo-32-caracteres
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
# Opcionais (auth.module / auth.service)
# JWT_ACCESS_EXPIRES=15m
# JWT_ACCESS_EXPIRES_SEC=
# JWT_REFRESH_EXPIRES_DAYS=30
# SESSION_SECRET=chave-sessao-producao

# --- CORS / frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
# CORS_METHODS=GET,POST,PUT,DELETE,PATCH

# --- Admin inicial / notificações (ADMIN_EMAIL usado em notification.service) ---
ADMIN_EMAIL=admin@seudominio.com
# Usado em templates de setup; confirme se o vosso seed/CLI ainda lê esta variável
ADMIN_PASSWORD=sua-senha-super-segura

# --- Rate limit ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=12

# --- Logs ---
LOG_LEVEL=info
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# --- SMTP (opcional) ---
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# SMTP_FROM=noreply@example.com

# --- Redis / cache (opcional; em dev pode usar memória) ---
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# CACHE_TTL=300
# CACHE_MAX=1000

# --- Base de dados direta (opcional; app usa sobretudo Supabase client) ---
# DATABASE_URL=
# DATABASE_SSL=false

# --- Monitoramento / backup (opcional; ver também production.config.ts) ---
METRICS_INTERVAL=60000
HEALTH_CHECK_INTERVAL=30000
ERROR_THRESHOLD=10
SLOW_REQUEST_THRESHOLD=1000
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
# BACKUP_PATH=/backups
# BACKUP_ENCRYPTION=false
# BACKUP_ENCRYPTION_KEY=
