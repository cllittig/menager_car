@startuml
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Visitante" as Visitante
actor "Usuario Autenticado" as Usuario
actor "Administrador" as Admin

Admin --|> Usuario

rectangle "Sistema Veicular" {
  usecase "Registrar Usuario" as UC_Register
  usecase "Realizar Login" as UC_Login
  usecase "Validar Credenciais" as UC_ValidateCredentials
  usecase "Gerar Token JWT" as UC_GenerateToken

  usecase "Consultar Status Do Sistema" as UC_Health

  usecase "Gerenciar Categorias\n(Criar, Listar, Buscar, Atualizar, Remover)" as UC_Categorias
  usecase "Gerenciar Fornecedores\n(Criar, Listar, Buscar, Atualizar, Remover)" as UC_Fornecedores
  usecase "Gerenciar Produtos\n(Criar, Listar, Buscar, Atualizar, Remover)" as UC_Produtos
  usecase "Gerenciar Usuarios\n(Listar, Buscar, Atualizar, Remover)" as UC_Usuarios

  usecase "Registrar Movimentacao" as UC_CreateMov
  usecase "Listar Movimentacoes" as UC_ListMov
  usecase "Buscar Movimentacao" as UC_GetMov
  usecase "Remover Movimentacao" as UC_RemoveMov
  usecase "Atualizar Estoque Do Produto" as UC_UpdateStock

  usecase "Gerenciar Veiculos\n(Criar, Listar, Buscar, Atualizar, Remover)" as UC_Veiculos
  usecase "Consultar Estatisticas De Veiculos" as UC_VehicleStats

  usecase "Gerenciar Contratos\n(Criar, Listar, Buscar, Atualizar, Remover)" as UC_Contratos
  usecase "Baixar Arquivo De Contrato" as UC_ContractFile
  usecase "Verificar Integridade De Contrato" as UC_ContractVerify
}

Visitante --> UC_Register
Visitante --> UC_Login

Usuario --> UC_Health
Usuario --> UC_Categorias
Usuario --> UC_Fornecedores
Usuario --> UC_Produtos
Usuario --> UC_Usuarios
Usuario --> UC_CreateMov
Usuario --> UC_ListMov
Usuario --> UC_GetMov
Usuario --> UC_RemoveMov
Usuario --> UC_Veiculos
Usuario --> UC_VehicleStats
Usuario --> UC_Contratos
Usuario --> UC_ContractFile
Usuario --> UC_ContractVerify

UC_Login .> UC_ValidateCredentials : <<include>>
UC_Login .> UC_GenerateToken : <<include>>

UC_CreateMov .> UC_UpdateStock : <<include>>
UC_RemoveMov .> UC_UpdateStock : <<include>>

UC_VehicleStats ..> UC_Veiculos : <<extend>>
UC_ContractFile ..> UC_Contratos : <<extend>>
UC_ContractVerify ..> UC_Contratos : <<extend>>

@enduml
