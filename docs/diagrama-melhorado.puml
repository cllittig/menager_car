@startuml SistemaVeicular

!define ABSTRACT_COLOR #E3F2FD
!define ENTITY_COLOR #F3E5F5
!define TRANSACTION_COLOR #E8F5E9
!define AUDIT_COLOR #FFF3E0

skinparam classBackgroundColor#E3F2FD
skinparam classBorderColor #1976D2
skinparam classArrowColor #1976D2
skinparam backgroundColor #FAFAFA
skinparam defaultFontSize 11
skinparam defaultFontFamily Courier
skinparam roundcorner 5

title <b>Sistema de Gestão Veicular</b>\nDiagrama de Classes - Principais Entidades

package "👤 Gestão de Usuários" #BBDEFB {

  class User {
    <b>-</b> id: UUID
    <b>-</b> email: String
    <b>-</b> password: String
    <b>-</b> name: String
    <b>-</b> role: Role
    <b>-</b> isActive: Boolean
    --
    <b>+</b> authenticate()
    <b>+</b> updatePassword()
    <b>+</b> logActivity()
  }

  class AuditLog {
    <b>-</b> id: UUID
    <b>-</b> action: String
    <b>-</b> entity: String
    <b>-</b> entityId: String
    <b>-</b> details: JSON
    <b>-</b> timestamp: DateTime
    --
    <b>+</b> recordAction()
    <b>+</b> getTrail()
  }
}

package "🚗 Gestão de Veículos" #CE93D8 {

  class Vehicle {
    <b>-</b> id: UUID
    <b>-</b> brand: String
    <b>-</b> model: String
    <b>-</b> year: Integer
    <b>-</b> licensePlate: String
    <b>-</b> chassis: String
    <b>-</b> mileage: Float
    <b>-</b> status: VehicleStatus
    <b>-</b> purchasePrice: Float
    <b>-</b> salePrice: Float
    --
    <b>+</b> updateStatus()
    <b>+</b> getMaintenance()
    <b>+</b> updateMileage()
  }

  class Maintenance {
    <b>-</b> id: UUID
    <b>-</b> description: String
    <b>-</b> cost: Float
    <b>-</b> startDate: DateTime
    <b>-</b> endDate: DateTime
    <b>-</b> status: MaintenanceStatus
    <b>-</b> mechanic: String
    --
    <b>+</b> startMaintenance()
    <b>+</b> completeMaintenance()
    <b>+</b> getTotalCost()
  }

  class ServiceOrder {
    <b>-</b> id: UUID
    <b>-</b> description: String
    <b>-</b> cost: Float
    <b>-</b> parts: String[]
    --
    <b>+</b> addPart()
    <b>+</b> calculateTotal()
  }
}

package "💰 Gestão de Transações" #A5D6A7 {

  class Client {
    <b>-</b> id: UUID
    <b>-</b> name: String
    <b>-</b> email: String
    <b>-</b> phone: String
    <b>-</b> cpf: String
    <b>-</b> cnh: String
    <b>-</b> address: String
    <b>-</b> isActive: Boolean
    --
    <b>+</b> validateDocuments()
    <b>+</b> getTransactionHistory()
  }

  class Transaction {
    <b>-</b> id: UUID
    <b>-</b> type: TransactionType
    <b>-</b> amount: Float
    <b>-</b> status: PaymentStatus
    <b>-</b> isActive: Boolean
    <b>-</b> createdAt: DateTime
    --
    <b>+</b> processPayment()
    <b>+</b> generateContract()
    <b>+</b> getInstallments()
  }

  class Installment {
    <b>-</b> id: UUID
    <b>-</b> number: Integer
    <b>-</b> amount: Float
    <b>-</b> dueDate: DateTime
    <b>-</b> status: PaymentStatus
    <b>-</b> paidAt: DateTime
    --
    <b>+</b> recordPayment()
    <b>+</b> isOverdue()
    <b>+</b> getInterest()
  }

  class Contract {
    <b>-</b> id: UUID
    <b>-</b> fileName: String
    <b>-</b> mimeType: String
    <b>-</b> fileSize: Int
    <b>-</b> fileHash: String
    <b>-</b> uploadDate: DateTime
    --
    <b>+</b> generateDocument()
    <b>+</b> validateIntegrity()
  }
}

User "1" --o "0..*" AuditLog : registra
Vehicle "1" --* "0..*" Maintenance : sofre
Vehicle "1" --* "0..*" Transaction : envolve
Client "1" --* "0..*" Transaction : participa
Transaction "1" --* "0..*" Installment : divide
Transaction "1" --* "1" Contract : gera
Maintenance "1" --* "0..*" ServiceOrder : contém

note right of User
  Controla acesso ao sistema
  com diferentes permissões
end note

note right of Vehicle
  Veículo é o ativo central
  sendo mantido e transacionado
end note

note right of Transaction
  Gerencia todas as operações
  de compra e venda
end note

@enduml
